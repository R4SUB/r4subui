[{"path":"https://r4sub.github.io/r4subui/authors.html","id":null,"dir":"","previous_headings":"","what":"Authors","title":"Authors and Citation","text":"Pawan Rama Mali. Author, maintainer, copyright holder.","code":""},{"path":"https://r4sub.github.io/r4subui/authors.html","id":"citation","dir":"","previous_headings":"","what":"Citation","title":"Authors and Citation","text":"Mali P (2026). r4subui: Interactive Dashboard Clinical Submission Readiness. R package version 0.1.0, https://r4sub.github.io/r4subui/.","code":"@Manual{,   title = {r4subui: Interactive Dashboard for Clinical Submission Readiness},   author = {Pawan Rama Mali},   year = {2026},   note = {R package version 0.1.0},   url = {https://r4sub.github.io/r4subui/}, }"},{"path":"https://r4sub.github.io/r4subui/index.html","id":"r4subui","dir":"","previous_headings":"","what":"r4subui — Interactive Dashboard for Clinical Submission Readiness","title":"r4subui — Interactive Dashboard for Clinical Submission Readiness","text":"r4subui interactive Shiny dashboard R4SUB ecosystem. visualizes evidence tables, pillar scores, Submission Confidence Index (SCI), indicator contributions, sensitivity analysis – single browser-based interface.","code":""},{"path":"https://r4sub.github.io/r4subui/index.html","id":"installation","dir":"","previous_headings":"","what":"Installation","title":"r4subui — Interactive Dashboard for Clinical Submission Readiness","text":"","code":"pak::pak(c(\"R4SUB/r4subcore\", \"R4SUB/r4subscore\", \"R4SUB/r4subui\"))"},{"path":"https://r4sub.github.io/r4subui/index.html","id":"quick-start","dir":"","previous_headings":"","what":"Quick Start","title":"r4subui — Interactive Dashboard for Clinical Submission Readiness","text":"","code":"library(r4subui)  # Launch with demo data ev <- generate_demo_evidence(n_rows = 100) r4sub_app(evidence = ev)  # Or launch with upload interface r4sub_app()"},{"path":[]},{"path":"https://r4sub.github.io/r4subui/index.html","id":"key-features","dir":"","pre